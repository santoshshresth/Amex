import pandas as pd
import os

def validate_and_save(input_path, output_path):
    if not os.path.exists(input_path):
        raise FileNotFoundError(f"File not found: {input_path}")

    df = pd.read_csv(input_path)

    initial_rows = len(df)

    df = df.drop_duplicates()

    if "SeriousDlqin2yrs" in df.columns:
        df = df.dropna(subset=["SeriousDlqin2yrs"])

    numeric_cols = df.select_dtypes(include=['number']).columns
    for col in numeric_cols:
        df = df[df[col] >= 0]

    if "age" in df.columns:
        df = df[(df["age"] > 0) & (df["age"] < 100)]

    final_rows = len(df)

    print(f" Rows before: {initial_rows}")
    print(f" Rows after validation: {final_rows}")

    df.to_csv(output_path, index=False)
    print(f" Validated file saved at: {output_path}")


input_file = "cs-training.csv"
output_file = "validated_cs_training.csv"

validate_and_save(input_file, output_file)
